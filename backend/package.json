{
  "name": "vote-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "db:migrate": "node -r dotenv/config build/schema/run-migrate.js",
    "snapshot": "node -r dotenv/config build/jobs/snapshot-job-cli.js",
    "proposal:deploy": "node -r dotenv/config build/services/proposal-lifecycle-cli.js deploy",
    "proposal:start-voting": "node -r dotenv/config build/services/proposal-lifecycle-cli.js start-voting",
    "proposal:end-voting": "node -r dotenv/config build/services/proposal-lifecycle-cli.js end-voting",
    "proposal:result": "node -r dotenv/config build/services/proposal-lifecycle-cli.js result"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ethers": "^6.16.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.6",
    "typescript": "^5.0.0"
  }
}
