# ---------------------------------------------------------------------------
# Corporate governance backend – environment example.
# Copy to .env and fill. Never commit .env or expose ADMIN_PRIVATE_KEY.
# ---------------------------------------------------------------------------

# PostgreSQL (identity, wallets, holdings, proposals, stake_snapshots)
DATABASE_URL=postgresql://user:password@localhost:5432/vote_governance

# Chain (admin wallet = chairperson for StakeVotingGovernance)
RPC_URL=http://127.0.0.1:8545
ADMIN_PRIVATE_KEY=0x...  # Chairperson wallet; used to deploy and call setProposal/assignStake/startVoting/endVoting

# Optional: path to Forge build artifact (for deploy). Default: vote/out/StakeVotingGovernance.sol/StakeVotingGovernance.json
# CONTRACT_ARTIFACT_PATH=/path/to/StakeVotingGovernance.json
